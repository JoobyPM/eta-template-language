{
  "name": "prettier-plugin-eta",
  "version": "0.1.0",
  "description": "Prettier plugin for Eta templates.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
