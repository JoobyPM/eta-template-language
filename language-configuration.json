{
  "comments": {
    "blockComment": ["<%/*", "*/%>"]
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["<%", "%>"]
  ],
  "autoClosingPairs": [
    { "open": "<%", "close": "%>" },
    { "open": "<%=", "close": "%>" },
    { "open": "<%~", "close": "%>" },
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""],
    ["'", "'"],
    ["<%", "%>"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*<%\\s*(if|for|while|switch|try|function).*\\{\\s*%>",
      "end": "^\\s*<%\\s*}\\s*%>"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@#%^&*()=+[\\]{}\\|;:'\",.<>/?\\s]+)"
}
